#! /bin/sh
# Generated by rstantools.  Do not edit by hand.

"${R_HOME}/bin/Rscript" -e "rstantools::rstan_config()"
# echo "PKG_CXXFLAGS += -Wa,-mbig-obj" >> ./src/Makevars
echo "CXX17FLAGS += -Wno-unused-variable -Wno-unused-function -Wno-unknown-pragmas -Wno-ignored-attributes -Wno-deprecated -Wno-pedantic -Wno-missing-template-arg-list-after-template-kw" >> ./src/Makevars
# Append to PKG_CXXFLAGS so the suppression comes after -Wall -pedantic (from StanHeaders::CxxFlags())
echo "PKG_CXXFLAGS += -Wno-missing-template-arg-list-after-template-kw" >> ./src/Makevars
# SSE/MMX optimization flags are only valid on x86_64, not ARM64
ARCH=$(uname -m)
if [ "$ARCH" = "x86_64" ]; then
  echo "CXX17FLAGS += -O3 -mmmx -msse -msse2 -msse3 -mssse3 -msse4.1 -msse4.2 -g0" >> ./src/Makevars
fi
